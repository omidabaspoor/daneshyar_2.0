# ============================================================
#  دانش‌یار - فایل تنظیمات محیطی (.env)
# ============================================================

# -------- تنظیمات پایگاه داده --------
DB_HOST=localhost
DB_NAME=daneshyar
DB_USER=daneshyar_user
DB_PASS=YOUR_SECURE_PASSWORD

# -------- امنیت و توسعه --------
DEV_MODE=false

# -------- سرویس هوش مصنوعی (GapGPT / OpenAI / Claude) --------
AI_API_URL=https://api.gapgpt.app/v1/chat/completions
AI_MODEL=gemini-3-flash-preview
AI_API_KEY=YOUR_GAPGPT_OR_LLM_API_KEY
AI_MAX_TOKENS=4096

# -------- دسترسی ادمین پنل مدیریت --------
ADMIN_USER=webmania
ADMIN_PASS=YOUR_SECURE_ADMIN_PASSWORD

# -------- محدودیت‌ها و حجم آپلود --------
FREE_DAILY_LIMIT=3
MAX_UPLOAD_MB=20

# -------- تنظیمات پرداخت کارت به کارت --------
CARD_NUMBER=6037990000000000
CARD_HOLDER=امید عباسپور
CARD_BANK=ملی

# -------- راه‌های ارتباط با ما --------
CONTACT_PHONE=09120000000
CONTACT_TELEGRAM=https://t.me/daneshyar_support

# -------- کانفیگ‌های جانبی cURL --------
CURL_INSECURE=false
